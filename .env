# ── Wallet (x402 receives USDC here — address only, no private key needed for receiving) ──
WALLET_ADDRESS=0x2DFe3B1C304DAd9F1b41D780ea81fCd137d810D8

# ── Coinbase CDP keys — REQUIRED for x402 payment verify/settle on Base Mainnet ──
# Get free keys at: https://portal.cdp.coinbase.com/
# Create an API key → copy Key ID and Key Secret below
# The /supported endpoint works without keys (used at boot for mainnet registration).
# Without keys: server boots, 402 responses are sent, but payments CANNOT be verified.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ── ACP (Virtuals Protocol — needs private key to sign job transactions) ──
# Use a DEDICATED wallet for this server, not your main wallet.
# Export from MetaMask: Settings > Account Details > Export Private Key
AGENT_WALLET_PRIVATE_KEY=

# ── GitHub API (free — 5000 req/hr vs 60 unauthenticated) ──
# Create at: https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=

# ── OpenSanctions API (sanctions screening — free 1000/day) ──
# Register at: https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=

# ── FRED API (Federal Reserve macro data — free) ──
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── NewsAPI (compliance news — free 100/day) ──
# Register at: https://newsapi.org/register
NEWS_API_KEY=

# ── Railway (auto-scaling — optional) ──
# Get token at: https://railway.app/account/tokens
# Project/Service IDs found in Railway dashboard → project settings
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=

# ── Server ──
PORT=3000
NODE_ENV=production
